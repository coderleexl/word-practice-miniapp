page {
  background: #f6f7fb;
  color: #172033;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #e6e9f0;
  border-radius: 16rpx;
  padding: 28rpx;
}

.primary-button {
  height: 88rpx;
  border-radius: 12rpx;
  background: #2f7dff;
  color: #ffffff;
  font-weight: 600;
  line-height: 88rpx;
}

.secondary-button {
  height: 88rpx;
  border: 1rpx solid #cbd5e1;
  border-radius: 12rpx;
  background: #ffffff;
  color: #172033;
  font-weight: 600;
  line-height: 88rpx;
}

.muted {
  color: #6b7280;
}
