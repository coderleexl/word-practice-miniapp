.result-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.result-hero {
  min-height: 310rpx;
  border-radius: 20rpx;
  background: #0f766e;
  color: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score {
  font-size: 108rpx;
  font-weight: 900;
  line-height: 1;
}

.score-unit {
  margin-top: 8rpx;
  font-weight: 700;
}

.summary {
  margin-top: 18rpx;
  color: #ccfbf1;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 16rpx;
}

.empty {
  color: #6b7280;
  padding: 28rpx 0;
}

.wrong-row {
  display: flex;
  justify-content: space-between;
  padding: 22rpx 0;
  border-top: 1rpx solid #eef2f7;
}

.wrong-row:first-of-type {
  border-top: 0;
}

.word {
  font-weight: 800;
}

.meaning {
  color: #6b7280;
}
