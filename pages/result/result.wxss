.result-page {
  padding: 32rpx;
  position: relative;
  overflow: hidden;
}

/* ── 撒花 ── */

.confetti-layer {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 99;
}

.confetti-particle {
  position: absolute;
  top: -20rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
  animation: confettiFall 2s ease-out forwards;
}

@keyframes confettiFall {
  0% {
    transform: translateY(0) rotate(0deg);
    opacity: 1;
  }
  100% {
    transform: translateY(1200rpx) rotate(720deg);
    opacity: 0;
  }
}

/* ── 成绩卡片 ── */

.score-card {
  text-align: center;
  padding: 60rpx 32rpx;
  margin-bottom: 24rpx;
}

.result-emoji {
  display: block;
  font-size: 80rpx;
  margin-bottom: 16rpx;
  animation: popIn 0.5s ease-out;
}

.result-title {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #3C3C3C;
  margin-bottom: 24rpx;
}

.result-score {
  display: block;
  font-size: 120rpx;
  font-weight: 900;
  color: #58CC02;
  line-height: 1;
}

.result-score-label {
  display: block;
  font-size: 32rpx;
  color: #777777;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.result-detail {
  display: block;
  font-size: 28rpx;
  color: #777777;
}

.xp-earned {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 24rpx;
  padding: 12rpx 32rpx;
  background: #FFF8E1;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #FFC800;
  animation: popIn 0.6s ease-out 0.3s both;
}

/* ── 错题列表 ── */

.wrong-section {
  margin-bottom: 24rpx;
}

.wrong-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.wrong-item:last-child {
  border-bottom: none;
}

.wrong-word {
  flex: 1;
}

.wrong-en {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #3C3C3C;
}

.wrong-phonetic {
  display: block;
  font-size: 22rpx;
  color: #777777;
}

.wrong-meaning {
  font-size: 28rpx;
  color: #3C3C3C;
  margin-right: 12rpx;
}

.wrong-type {
  font-size: 22rpx;
  color: #777777;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
