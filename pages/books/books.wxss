.books-page {
  padding: 24rpx 32rpx;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 800;
}

.word-count-badge {
  font-size: 24rpx;
  font-weight: 700;
  color: #1CB0F6;
  background: #ddf3ff;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
}

.add-form {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.form-input {
  height: 88rpx;
  border: 3rpx solid #E5E5E5;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  background: #ffffff;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #777777;
  font-size: 28rpx;
}

/* 教材卡片 */
.book-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: transform 0.1s;
}

.book-card:active {
  transform: scale(0.98);
}

.book-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
}

.book-meta {
  display: block;
  font-size: 24rpx;
  color: #777777;
  margin-top: 4rpx;
}

.book-arrow {
  font-size: 36rpx;
  color: #1CB0F6;
  font-weight: 700;
}

/* 单元卡片 */
.unit-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.unit-info {
  flex: 1;
}

.unit-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
}

.unit-meta {
  display: block;
  font-size: 24rpx;
  color: #777777;
  margin-top: 4rpx;
}

.unit-actions {
  display: flex;
  gap: 28rpx;
}

.action-link {
  font-size: 26rpx;
  font-weight: 600;
  color: #1CB0F6;
}

.action-link.danger {
  color: #FF4B4B;
}

/* 单词列表 */
.word-list {
  max-height: 60vh;
  overflow-y: auto;
}

.word-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.word-row:last-child {
  border-bottom: none;
}

.word-text {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
}

.word-text-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.speak-icon {
  font-size: 28rpx;
  cursor: pointer;
}

.speak-icon:active {
  opacity: 0.7;
}

.word-phonetic {
  display: block;
  font-size: 24rpx;
  color: #777777;
  margin-top: 4rpx;
}

.word-meaning {
  font-size: 28rpx;
  color: #3C3C3C;
}

.word-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.word-delete {
  font-size: 24rpx;
  color: #FF4B4B;
  font-weight: 600;
}

.add-word-form {
  margin-bottom: 20rpx;
}

.form-row {
  display: flex;
  gap: 16rpx;
}

.word-count-bar {
  margin-bottom: 16rpx;
}

.word-count-text {
  font-size: 24rpx;
  color: #777777;
}
