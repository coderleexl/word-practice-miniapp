.exam-page {
  padding: 24rpx 32rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.page-subtitle {
  display: block;
  font-size: 28rpx;
  color: #777777;
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.select-all {
  font-size: 26rpx;
  color: #1CB0F6;
  font-weight: 600;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  padding: 16rpx 28rpx;
  border: 3rpx solid #E5E5E5;
  border-radius: 999rpx;
  font-size: 28rpx;
  background: #ffffff;
  font-weight: 600;
}

.chip-active {
  border-color: #1CB0F6;
  background: #ddf3ff;
  color: #1CB0F6;
}

.empty-hint {
  color: #777777;
  font-size: 26rpx;
}

.count-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.count-input {
  width: 160rpx;
  height: 80rpx;
  border: 3rpx solid #E5E5E5;
  border-radius: 16rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
}

.count-hint {
  font-size: 26rpx;
  color: #777777;
}

/* 题型比例 */
.type-ratio-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.type-ratio-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.type-ratio-name {
  font-size: 28rpx;
  font-weight: 600;
}

.type-ratio-controls {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.ratio-btn {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #1CB0F6;
  background: #ddf3ff;
  border-radius: 50%;
}

.type-ratio-value {
  font-size: 32rpx;
  font-weight: 700;
  min-width: 40rpx;
  text-align: center;
}

.ratio-hint {
  display: block;
  font-size: 22rpx;
  color: #777777;
  margin-top: 12rpx;
}

/* 答题 */
.progress-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.progress-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #777777;
  min-width: 80rpx;
}

.question-card {
  text-align: center;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  border: 4rpx solid transparent;
  transition: border-color 0.3s, background 0.3s;
}

.card-correct {
  border-color: #58CC02;
  background: #f0ffe0;
}

.card-wrong {
  border-color: #FF4B4B;
  background: #fff0f0;
}

.question-type {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #1CB0F6;
  margin-bottom: 16rpx;
}

.question-prompt {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.3;
  margin-bottom: 12rpx;
}

.question-hint {
  display: block;
  font-size: 28rpx;
  color: #777777;
}

.options-area.disabled {
  pointer-events: none;
}

.spelling-area {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.scrambled-box {
  text-align: center;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.scrambled-label {
  display: block;
  font-size: 22rpx;
  color: #777777;
  margin-bottom: 8rpx;
}

.scrambled-letters {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  letter-spacing: 10rpx;
  color: #1CB0F6;
}

.spelling-input-row {
  display: flex;
  gap: 16rpx;
}

.spelling-input {
  flex: 1;
  height: 88rpx;
  border: 3rpx solid #E5E5E5;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  text-align: center;
  background: #ffffff;
}

.feedback-bar {
  padding: 24rpx;
  border-radius: 16rpx;
  text-align: center;
  font-weight: 700;
  font-size: 28rpx;
  margin-bottom: 24rpx;
}

.feedback-bar.correct {
  background: #d7ffb8;
  color: #58CC02;
}

.feedback-bar.wrong {
  background: #ffd4d4;
  color: #FF4B4B;
}

/* 结果 */
.score-card {
  text-align: center;
  padding: 60rpx 32rpx;
  margin-bottom: 24rpx;
}

.result-emoji {
  display: block;
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.result-score {
  display: block;
  font-size: 120rpx;
  font-weight: 900;
  color: #58CC02;
  line-height: 1;
}

.result-score-label {
  display: block;
  font-size: 32rpx;
  color: #777777;
  margin-bottom: 12rpx;
}

.result-detail {
  display: block;
  font-size: 28rpx;
  color: #777777;
}

.wrong-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.wrong-item:last-child {
  border-bottom: none;
}

.wrong-en {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
}

.wrong-phonetic {
  display: block;
  font-size: 24rpx;
  color: #777777;
}

.wrong-type {
  font-size: 22rpx;
  color: #777777;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
