.practice-page {
  padding: 24rpx 32rpx;
  position: relative;
  overflow: hidden;
}

/* ── 进度 ── */

.progress-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.progress-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #777777;
  min-width: 80rpx;
}

/* ── 题目卡片 ── */

.question-card {
  text-align: center;
  padding: 48rpx 32rpx;
  margin-bottom: 32rpx;
  transition: border-color 0.3s, background 0.3s;
  border: 4rpx solid transparent;
}

.card-correct {
  border-color: #58CC02;
  background: #f0ffe0;
}

.card-wrong {
  border-color: #FF4B4B;
  background: #fff0f0;
}

.question-type {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #1CB0F6;
  margin-bottom: 20rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.question-prompt {
  display: block;
  font-size: 52rpx;
  font-weight: 800;
  color: #3C3C3C;
  line-height: 1.3;
  margin-bottom: 12rpx;
}

.question-hint {
  display: block;
  font-size: 28rpx;
  color: #777777;
}

/* ── 选项 ── */

.options-area.disabled {
  pointer-events: none;
}

/* ── 拼写题 ── */

.spelling-area {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.scrambled-box {
  text-align: center;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.scrambled-label {
  display: block;
  font-size: 22rpx;
  color: #777777;
  margin-bottom: 12rpx;
}

.scrambled-letters {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: 12rpx;
  color: #1CB0F6;
}

.spelling-input-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.spelling-input {
  flex: 1;
  height: 96rpx;
  border: 3rpx solid #E5E5E5;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 32rpx;
  text-align: center;
  background: #ffffff;
  box-shadow: 0 4rpx 0 #d4d4d4;
}

.spelling-input:focus {
  border-color: #1CB0F6;
}

.spelling-submit {
  width: 160rpx;
  flex-shrink: 0;
}

.spelling-answer {
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-weight: 700;
  font-size: 30rpx;
}

.spelling-answer.correct {
  background: #d7ffb8;
  color: #58CC02;
}

.spelling-answer.wrong {
  background: #ffd4d4;
  color: #FF4B4B;
}

/* ── 配对题 ── */

.matching-area {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.matching-status {
  text-align: center;
  font-size: 26rpx;
  color: #777777;
  font-weight: 600;
}

.matching-columns {
  display: flex;
  gap: 20rpx;
}

.matching-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.col-title {
  font-size: 22rpx;
  color: #777777;
  text-align: center;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.match-item {
  padding: 24rpx 16rpx;
  text-align: center;
  border: 3rpx solid #E5E5E5;
  border-radius: 16rpx;
  background: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 0 #d4d4d4;
}

.match-item.selected {
  border-color: #1CB0F6;
  background: #ddf3ff;
  color: #1CB0F6;
}

.match-item.matched {
  border-color: #58CC02;
  background: #d7ffb8;
  color: #58CC02;
  box-shadow: 0 2rpx 0 #46a302;
}

/* ── XP 飞入 ── */

.floating-xp {
  position: fixed;
  top: 40%;
  right: 60rpx;
  font-size: 40rpx;
  font-weight: 800;
  color: #FFC800;
  z-index: 100;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
  animation: xpFloat 1.2s ease-out forwards;
}

/* ── 撒花粒子 ── */

.confetti-layer {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 99;
}

.confetti-particle {
  position: absolute;
  top: 30%;
  border-radius: 4rpx;
  animation: confettiFall 1s ease-out forwards;
}

@keyframes confettiFall {
  0% {
    transform: translateY(0) rotate(0deg) scale(1);
    opacity: 1;
  }
  100% {
    transform: translateY(600rpx) rotate(720deg) scale(0.3);
    opacity: 0;
  }
}

/* ── 反馈条 ── */

.feedback-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 28rpx 32rpx;
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  z-index: 50;
}

.feedback-bar.correct {
  background: #58CC02;
  color: #ffffff;
}

.feedback-bar.wrong {
  background: #FF4B4B;
  color: #ffffff;
}

/* ── 朗读按钮 ── */

.question-prompt-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.speak-btn {
  font-size: 40rpx;
  padding: 8rpx;
  cursor: pointer;
}

.speak-btn:active {
  opacity: 0.7;
  transform: scale(0.95);
}
