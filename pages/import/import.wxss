.import-page {
  padding: 24rpx 32rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.page-subtitle {
  display: block;
  font-size: 28rpx;
  color: #777777;
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.paste-area {
  width: 100%;
  min-height: 200rpx;
  border: 3rpx solid #E5E5E5;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 24rpx;
  font-family: monospace;
  box-sizing: border-box;
  margin-bottom: 16rpx;
  background: #fafafa;
}

.field-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.field-row:last-child {
  border-bottom: none;
}

.field-name {
  font-weight: 700;
  font-family: monospace;
  font-size: 26rpx;
}

.field-name.required {
  color: #FF4B4B;
}

.field-desc {
  color: #777777;
  font-size: 26rpx;
}

/* 预览 */
.preview-stats {
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: #777777;
}

.preview-table-wrap {
  margin-bottom: 24rpx;
}

.preview-row {
  display: flex;
  border-bottom: 1rpx solid #f5f5f5;
}

.preview-header {
  background: #f9f9f9;
  font-weight: 600;
  font-size: 22rpx;
}

.preview-cell {
  min-width: 140rpx;
  padding: 12rpx 8rpx;
  font-size: 22rpx;
  flex-shrink: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 导入目标 */
.import-target {
  margin: 24rpx 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #777777;
  margin-bottom: 8rpx;
  font-weight: 600;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  padding: 12rpx 28rpx;
  border: 3rpx solid #E5E5E5;
  border-radius: 999rpx;
  font-size: 26rpx;
  background: #ffffff;
  font-weight: 600;
}

.chip-active {
  border-color: #1CB0F6;
  background: #ddf3ff;
  color: #1CB0F6;
}

.form-group {
  display: flex;
  flex-direction: column;
}

.form-input {
  height: 80rpx;
  border: 3rpx solid #E5E5E5;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #ffffff;
}

/* 字段映射 */
.mapping-hint {
  display: block;
  font-size: 24rpx;
  color: #777777;
  margin-bottom: 16rpx;
}

.mapping-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.mapping-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.mapping-source {
  flex: 1;
  font-size: 26rpx;
  font-weight: 600;
  font-family: monospace;
  background: #f5f5f5;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mapping-arrow {
  font-size: 24rpx;
  color: #777777;
}

.mapping-target {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 26rpx;
  padding: 12rpx 16rpx;
  background: #ffffff;
  border: 3rpx solid #E5E5E5;
  border-radius: 8rpx;
}

.picker-arrow {
  font-size: 20rpx;
  color: #777777;
}

.load-hint {
  display: block;
  font-size: 24rpx;
  color: #777777;
  margin-bottom: 16rpx;
}

/* GitHub词库列表 */
.github-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 16rpx;
}

.github-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.github-info {
  flex: 1;
}

.github-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
}

.github-count {
  display: block;
  font-size: 22rpx;
  color: #777777;
  margin-top: 4rpx;
}

.btn-sm {
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  min-height: auto;
  line-height: 1.5;
}
